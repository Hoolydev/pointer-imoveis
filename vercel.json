{
  "version": 2,
  "buildCommand": "pnpm -r build",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/apps/api/api/index" }
  ],
  "functions": {
    "apps/api/api/index.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "crons": [
    { "path": "/api/cron/drain", "schedule": "* * * * *" }
  ]
}

# Database (Neon Postgres)
DATABASE_URL="postgresql://user:pass@host.neon.tech/db?sslmode=require"

# Redis (Upstash recommended; must support BullMQ — use Upstash "TLS Redis" not REST)
REDIS_URL="rediss://default:password@host.upstash.io:6379"

# LLM
OPENAI_API_KEY="sk-..."
LLM_MODEL="gpt-4o-mini"

# WhatsApp providers
WHATSAPP_PROVIDER="uazapi"               # uazapi | official | mock

UAZAPI_BASE_URL="https://free.uazapi.com"
UAZAPI_TOKEN=""
UAZAPI_INSTANCE=""

WHATSAPP_OFFICIAL_TOKEN=""
WHATSAPP_OFFICIAL_PHONE_ID=""
WHATSAPP_OFFICIAL_VERIFY_TOKEN="changeme"

# Cron + internal calls
CRON_SECRET="rotate-me"
PUBLIC_BASE_URL="http://localhost:3001"   # used by drain self-chain
